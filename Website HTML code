            border-radius: 20px;
            padding: 1rem;
            height: 300px;
            overflow: hidden;
        }

        .signup-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 15px;
        }

        /* Feedback Section */
        .feedback-section {
            background: #FFE566;
            padding: 4rem 2rem;
            position: relative;
            overflow: hidden;
        }

        .feedback-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .feedback-section h2 {
            font-size: 3rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: #000;
        }

        .feedback-section h3 {
            font-size: 1.5rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: #000;
        }

        .email-info {
            margin: 1.5rem 0;
        }

        .email-info p {
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

        .email-link {
            color: #0066CC;
            text-decoration: none;
            font-size: 1.1rem;
        }

        .feedback-box {
            background: #B3E5FC;
            padding: 2rem;
            border-radius: 15px;
        }

        .feedback-box p {
            margin-bottom: 1rem;
            font-weight: 500;
        }

        .feedback-box textarea {
            width: 100%;
            padding: 1rem;
            border: none;
            border-radius: 10px;
            font-family: inherit;
            font-size: 1rem;
            margin-bottom: 1rem;
            min-height: 120px;
            resize: vertical;
        }

        .feedback-box button {
            padding: 0.8rem 2rem;
            background: #000;
            color: #fff;
            border: none;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .feedback-box button:hover {
            background: #333;
            transform: translateY(-2px);
        }

        .privacy-note {
            font-size: 0.85rem;
            margin-top: 0.5rem;
            opacity: 0.8;
        }

        .swimmer-illustration {
            position: absolute;
            right: 5%;
            bottom: 0;
            font-size: 10rem;
            opacity: 0.2;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .hero {
                flex-direction: column;
                text-align: center;
            }

            .hero h1 {
                font-size: 3rem;
            }

            .hero p {
                max-width: 100%;
            }

            .location-content,
            .schedule-header,
            .qualify-container,
            .signup-content,
            .feedback-container {
                grid-template-columns: 1fr;
            }

            .calendar-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.5rem;
            }

            .info-section h2,
            .feedback-section h2 {
                font-size: 2rem;
            }

            .location-text h3,
            .qualify-section h2,
            .signup-section h2 {
                font-size: 2rem;
            }

            .info-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
        }
    </style>
</head>

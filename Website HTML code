            background: #0066CC;
            color: #fff;
            padding: 2.5rem;
            border-radius: 20px;
        }

        .qualify-card h3 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
        }

        .qualify-list {
            list-style: none;
            margin-bottom: 2rem;
        }

        .qualify-list li {
            padding: 0.8rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            font-size: 1.1rem;
        }

        .qualify-list li:before {
            content: "✓ ";
            margin-right: 0.5rem;
        }

        .confirm-btn {
            display: inline-block;
            padding: 1rem 3rem;
            background: #fff;
            color: #0066CC;
            text-decoration: none;
            font-weight: bold;
            border-radius: 5px;
            transition: all 0.3s;
        }

        .confirm-btn:hover {
            transform: scale(1.05);
        }

        /* Sign Up Section */
        .signup-section {
            background: #E0F7FA;
            padding: 4rem 2rem;
        }

        .signup-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .signup-section h2 {

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            line-height: 1.6;
            color: #000;
            background: #fff;
        }

        /* Hero Section */
        .hero {
            background: #fff;
            padding: 4rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            max-width: 1400px;
            margin: 0 auto;
            flex-wrap: wrap;
            gap: 2rem;
        }

        .hero-content {
            flex: 1;
            min-width: 300px;
        }

        .hero h1 {
            font-size: 4rem;
            font-weight: 900;
            margin-bottom: 1rem;
            line-height: 1.1;
            color: #000;
        }

        .hero p {
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 2rem;
            color: #333;
            max-width: 500px;
        }

        .hero-image {
            flex: 1;
            min-width: 300px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .hero-image-container {
            background: #FFE566;
            border-radius: 50% 50% 0 50%;
            padding: 2rem;
            width: 100%;
            max-width: 400px;
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .hero-image-placeholder {
            width: 90%;
            height: 90%;
            background: url('data:image/jpeg;base64,') center/cover;
            border-radius: 20px;
            overflow: hidden;
        }

        .learn-more-btn {
            display: inline-block;
            padding: 0.8rem 2rem;
            background: #000;
            color: #fff;
            text-decoration: none;
            font-weight: bold;
            border-radius: 5px;
            transition: all 0.3s;
        }

        .learn-more-btn:hover {
            background: #333;
            transform: translateY(-2px);
        }

        /* Information Section */
        .info-section {
            background: #E0F7FA;
            padding: 4rem 2rem;
        }

        .info-section-header {
            max-width: 1400px;
            margin: 0 auto 3rem;
        }

        .info-section h2 {
            font-size: 3rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: #000;
        }

        .info-section p {
            font-size: 1.1rem;
            color: #333;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 3rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .info-card {
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            color: inherit;
        }

        .info-card:hover {
            transform: translateY(-5px);
        }

        .info-icon {
            width: 100px;
            height: 100px;
            margin: 0 auto 1rem;
            background: #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
        }

        .info-card h3 {
            font-size: 1.3rem;
            font-weight: bold;
            margin-bottom: 0.5rem;
            color: #000;
        }

        /* Location Section */
        .location-section {
            background: #FFF9E6;
            padding: 4rem 2rem;
        }

        .location-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .location-section h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 2rem;
            color: #000;
        }

        .location-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: start;
        }

        .location-text h3 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            color: #000;
        }

        .directions-box {
            background: #fff;
            padding: 1.5rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
        }

        .directions-box h4 {
            font-weight: bold;
            margin-bottom: 1rem;
            color: #000;
        }

        .directions-box p {
            line-height: 1.8;
            margin-bottom: 0.5rem;
        }

        .gps-box {
            background: #fff;
            padding: 1.5rem;
            border-radius: 10px;
        }

        .gps-box h4 {
            font-weight: bold;
            margin-bottom: 0.5rem;
            color: #000;
        }

        .location-map {
            background: #E0F7FA;
            border-radius: 20px;
            overflow: hidden;
            min-height: 400px;
        }

        .location-map iframe {
            width: 100%;
            height: 100%;
            min-height: 400px;
            border: none;
            border-radius: 20px;
        }

        /* Schedule Section */
        .schedule-section {
            background: #fff;
            padding: 4rem 2rem;
        }

        .schedule-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .schedule-header {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            margin-bottom: 3rem;
            align-items: center;
        }

        .schedule-title h2 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: #000;
        }

        .cohort-card {
            background: #E0F7FA;
            padding: 2rem;
            border-radius: 20px;
            text-align: center;
        }

        .cohort-card h3 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: #000;
        }

        .pool-image {
            width: 100%;
            height: 200px;
            background: url('https://i.imgur.com/wKNT8Ic.png') center/cover;
            border-radius: 15px;
            margin-bottom: 1rem;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .calendar {
            background: #E0F7FA;
            padding: 1.5rem;
            border-radius: 15px;
        }

        .calendar h4 {
            font-size: 1.5rem;
            font-weight: 900;
            margin-bottom: 1rem;
            color: #000;
        }

        .calendar-header {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
            margin-bottom: 5px;
        }

        .calendar-day-name {
            text-align: center;
            font-weight: bold;
            font-size: 0.8rem;
            padding: 0.3rem;
            background: #FFE566;
            border-radius: 3px;
        }

        .calendar-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border-radius: 5px;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .calendar-day.lesson {
            background: #4DD0E1;
            font-weight: bold;
        }

        .calendar-day.empty {
            background: transparent;
        }

        .legend {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .legend-box {
            width: 30px;
            height: 20px;
            background: #4DD0E1;
            border-radius: 3px;
        }

        /* Qualify Section */
        .qualify-section {
            background: #FFE566;
            padding: 4rem 2rem;
        }

        .qualify-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .qualify-section h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 2rem;
            color: #000;
        }


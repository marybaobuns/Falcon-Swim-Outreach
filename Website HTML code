                <ul class="qualify-list">
                    <li>Is 4 years or older</li>
                    <li>Is potty trained</li>
                    <li>Comes from a low income household according to the "2025 AFFORDABLE HOUSING REGIONAL INCOME LIMITS BY HOUSEHOLD SIZE"</li>
                    <li>(mostly) Speaks and understands English</li>
                </ul>
                <a href="#signup" class="confirm-btn">Confirm</a>
            </div>
        </div>
    </section>

    <!-- Sign Up Section -->
    <section class="signup-section" id="signup">
        <div class="signup-container">
            <h2>HOW TO SIGN UP?</h2>
            <div class="signup-content">
                <div class="signup-image">
                    <div class="signup-image-container">
                        🏊
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Feedback Section -->
    <section class="feedback-section">
        <div class="feedback-container">
            <div>
                <h2>Questions or suggestions?</h2>
                <h3>REACH OUT!</h3>
                <div class="email-info">
                    <p>Email:</p>
                    <a href="mailto:falconswimoutreach@peddie.org" class="email-link">falconswimoutreach@peddie.org</a>
                </div>
            </div>
            <div class="feedback-box">
                <p>Was this website helpful?</p>
                <textarea id="feedbackText" placeholder="Your feedback here..."></textarea>
                <button onclick="submitFeedback()">Submit Feedback</button>
                <p class="privacy-note">Your name will not be shared</p>
            </div>
        </div>
        <div class="swimmer-illustration">🏊‍♂️</div>
    </section>

    <script>
        function submitFeedback() {
            const feedback = document.getElementById('feedbackText').value;
            if (feedback.trim()) {
                const subject = encodeURIComponent('Website Feedback');
                const body = encodeURIComponent(feedback);
                window.location.href = `mailto:falconswimoutreach@peddie.org?subject=${subject}&body=${body}`;
                document.getElementById('feedbackText').value = '';
                alert('Thank you! Your default email client will open to send your feedback.');
            } else {
                alert('Please enter your feedback before submitting.');
            }
        }

        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>
